model Booking {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  phone         String
  email         String
  carModel      String
  year          Int
  // Optional: записи, створені до появи поля, його не мають
  preferredDate DateTime?
  message       String?
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
